# Generated by TeddyCloudHelper — do not edit by hand, re-run the setup wizard instead.
services:
  teddycloud:
    image: ghcr.io/toniebox-reverse-engineering/teddycloud:{{ teddycloud_image_tag }}
    container_name: teddycloud
    restart: unless-stopped
    volumes:
      - ./certs:/teddycloud/certs
      - ./config:/teddycloud/config
      - ./content:/teddycloud/data/content
      - ./library:/teddycloud/data/library
      - ./custom_img:/teddycloud/data/www/custom_img
      - ./firmware:/teddycloud/data/firmware
      - ./cache:/teddycloud/data/cache
      - ./plugins:/teddycloud/data/www/plugins
{%- if deployment_mode == "direct" %}
    ports:
      - "{{ http_port }}:80"
      - "443:443"
      - "{{ webui_port }}:8443"
{%- endif %}
{%- if deployment_mode == "nginx" %}

  nginx:
    image: nginx:stable-alpine
    container_name: teddycloud-nginx
    restart: unless-stopped
    depends_on:
      - teddycloud
{%- if letsencrypt_enabled %}
    # Reload periodically so renewed Let's Encrypt certs are picked up.
    command: /bin/sh -c 'while :; do sleep 6h & wait $$!; nginx -s reload; done & exec nginx -g "daemon off;"'
{%- endif %}
    ports:
      - "{{ http_port }}:80"
      - "443:443"
{%- if webui_port_mode == "separate" %}
      - "{{ webui_port }}:{{ webui_port }}"
{%- endif %}
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./webui-pki:/etc/teddycloudhelper/webui-pki:ro
      - ./certbot-www:/var/www/certbot:ro
{%- if basic_auth_enabled %}
      - ./security:/etc/teddycloudhelper/security:ro
{%- endif %}
{%- if letsencrypt_enabled %}
      - ./letsencrypt:/etc/letsencrypt:ro

  certbot:
    image: certbot/certbot
    container_name: teddycloud-certbot
    restart: unless-stopped
    entrypoint: /bin/sh -c 'trap exit TERM; while :; do certbot renew --webroot -w /var/www/certbot; sleep 12h & wait $$!; done'
    volumes:
      - ./letsencrypt:/etc/letsencrypt
      - ./certbot-www:/var/www/certbot
{%- endif %}
{%- endif %}
