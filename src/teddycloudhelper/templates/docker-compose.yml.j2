# Generated by TeddyCloudHelper — do not edit by hand, re-run the setup wizard instead.
services:
  teddycloud:
    image: ghcr.io/toniebox-reverse-engineering/teddycloud:latest
    container_name: teddycloud
    restart: unless-stopped
    volumes:
      - ./certs:/teddycloud/certs
      - ./config:/teddycloud/config
      - ./content:/teddycloud/content
      - ./library:/teddycloud/library
{%- if deployment_mode == "direct" %}
    ports:
      - "{{ http_port }}:80"
      - "443:443"
      - "{{ webui_port }}:8443"
{%- endif %}
{%- if deployment_mode == "nginx" %}

  nginx:
    image: nginx:stable-alpine
    container_name: teddycloud-nginx
    restart: unless-stopped
    depends_on:
      - teddycloud
    ports:
      - "{{ http_port }}:80"
      - "443:443"
{%- if webui_port_mode == "separate" %}
      - "{{ webui_port }}:{{ webui_port }}"
{%- endif %}
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./webui-pki:/etc/teddycloudhelper/webui-pki:ro
{%- if basic_auth_enabled %}
      - ./security:/etc/teddycloudhelper/security:ro
{%- endif %}
{%- endif %}
