# Generated by TeddyCloudHelper — do not edit by hand, re-run the setup wizard instead.
#
# Port 443 is the Toniebox endpoint: the box authenticates with a client
# certificate directly against TeddyCloud (mTLS), so this config only ever
# does raw TLS passthrough on the box path — never TLS termination.

user nginx;
worker_processes auto;

events {
    worker_connections 1024;
}

stream {
{%- if webui_port_mode == "shared" %}
    # SNI split: the WebUI hostname is terminated locally (loopback server
    # below); everything else — including boxes that send no SNI at all —
    # is passed through untouched to TeddyCloud.
    map $ssl_preread_server_name $upstream_443 {
        {{ webui_hostname }} 127.0.0.1:8444;
        default teddycloud:443;
    }

    server {
        listen 443;
        ssl_preread on;
        resolver 127.0.0.11 valid=30s;
        proxy_pass $upstream_443;
    }
{%- else %}
    # Separate WebUI port: all of 443 belongs to the box path.
    server {
        listen 443;
        proxy_pass teddycloud:443;
    }
{%- endif %}
}

http {
    # TAF uploads through the WebUI can be huge — no body size limit.
    client_max_body_size 0;
    # TeddyCloud can take minutes to consume large uploads (ESP32 firmware
    # dumps, TAF files) — the 60s defaults cut them off with a 502/504.
    proxy_read_timeout 600s;
    proxy_send_timeout 600s;
    # The WebUI gets live updates via SSE (/api/sse); response buffering
    # would hold those events back.
    proxy_buffering off;
    # CRITICAL: TeddyCloud's HTTP server loses request-body bytes that
    # arrive in the same burst as the headers (no Expect: 100-continue),
    # then stalls ~120s and drops the connection — uploads through a
    # buffering proxy always fail with 502. Streaming the body keeps the
    # headers in their own packet and avoids the bug entirely.
    proxy_request_buffering off;

    map $http_upgrade $connection_upgrade {
        default upgrade;
        '' close;
    }

    # Plain HTTP: ACME challenges only, everything else is redirected to
    # the TLS WebUI. NEVER proxied to TeddyCloud — unauthenticated internet
    # noise (crawlers, /.env scanners) reaching TeddyCloud triggers its
    # security-mitigation lock, which also cuts off the boxes.
    server {
        listen 80;
        # ACME HTTP-01 challenge — must stay reachable for everyone.
        location /.well-known/acme-challenge/ {
            root /var/www/certbot;
        }
        location / {
{%- if webui_port_mode == "separate" %}
            return 301 https://$host:{{ webui_port }}$request_uri;
{%- else %}
            return 301 https://$host$request_uri;
{%- endif %}
        }
    }

    # TLS-terminated WebUI.
    server {
{%- if webui_port_mode == "shared" %}
        listen 127.0.0.1:8444 ssl;
{%- else %}
        listen {{ webui_port }} ssl;
{%- endif %}
        server_name {{ webui_hostname }};
{%- if ip_allowlist %}
{%- for entry in ip_allowlist %}
        allow {{ entry }};
{%- endfor %}
        deny all;
{%- endif %}
{%- if basic_auth_enabled %}
        auth_basic "TeddyCloud WebUI";
        auth_basic_user_file /etc/teddycloudhelper/security/htpasswd;
{%- endif %}

{%- if webui_tls_mode == "letsencrypt" %}
        ssl_certificate     /etc/letsencrypt/live/{{ webui_hostname }}/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/{{ webui_hostname }}/privkey.pem;
{%- else %}
        ssl_certificate     /etc/teddycloudhelper/webui-pki/server/server.crt;
        ssl_certificate_key /etc/teddycloudhelper/webui-pki/server/server.key;
{%- endif %}
{%- if webui_client_cert_auth %}
        ssl_client_certificate /etc/teddycloudhelper/webui-pki/ca/ca.crt;
        ssl_crl                /etc/teddycloudhelper/webui-pki/crl/ca.crl;
        ssl_verify_client on;
{%- endif %}

        location / {
            proxy_pass http://teddycloud:80;
            proxy_set_header Host $host;
            proxy_set_header X-Forwarded-Proto https;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
        }
    }
}
